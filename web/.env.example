# SkillStore Environment Variables
# Copy this to .env.local and fill in values as needed.

# === GitHub Auth (optional) ===
# Personal access token for higher API rate limits (60 -> 5,000 req/hr)
# Required if your self-hosted fork is a private repository
GITHUB_TOKEN=

# === NextAuth (required for enterprise features) ===
# Generate with: npx auth secret
AUTH_SECRET=
# Create a GitHub OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://your-domain.com/api/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# === Supabase (required for enterprise features) ===
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Self-Hosted Fork (optional) ===
# Override these to point the web catalog at your fork instead of philkomarny/SkillStore.
# Most enterprises should use the context repo approach (see /enterprise) instead.
SKILLSTORE_REPO_OWNER=
SKILLSTORE_REPO_NAME=
SKILLSTORE_BRANCH=
